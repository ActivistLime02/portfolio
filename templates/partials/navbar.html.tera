<div>
    <div>

    </div>
    <nav class="bg-ctp-surface0 sm:flex sm:justify-between"
         x-data="{ open: false }"
    >
        <div class="flex justify-between">
            <a href="/"><img class="h-[56px] p-2 px-4" src="/public/logo.svg" alt="Logo met de letters NH"></a>
            <button class="p-4 cursor-pointer sm:hidden"
                    @click="open = !open">
                <i class="fa-solid fa-bars"
                   x-show="!open"
                ></i>
                <i class="fa-solid fa-chevron-up"
                   x-show="open"
                ></i>
            </button>
        </div>
        {# Note to myself: `sm:!flex` ensures that display if not set to none due to alpine. TLDR, don't remove `sm:!flex`! #}
        <ul x-show="open" class="flex flex-col max-h-[50vh] overflow-auto
    {# 'reset' to large screen #}
    sm:!flex sm:flex-row sm:max-h-none sm:overflow-visible">
            <li class=""><a class="w-full sm:w-auto inline-block p-4 hover:text-ctp-rosewater hover:bg-ctp-mantle
            {% if navbar_active_state == "index" %} bg-ctp-surface1 {% endif %}"
                href="/">Hoofdpagina</a></li>
            <li class=""><a class="w-full sm:w-auto inline-block p-4 hover:text-ctp-rosewater hover:bg-ctp-mantle
            {% if navbar_active_state == "aboutme" %} bg-ctp-surface1 {% endif %}"
                href="/aboutme">Over mij</a></li>
        </ul>
    </nav>
</div>